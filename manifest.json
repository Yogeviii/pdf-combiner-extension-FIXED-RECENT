{
  "manifest_version": 3,
  "name": "Local PDF Combiner",
  "version": "1.0.0",
  "description": "Combine JPG, JPEG, PNG, WebP, GIF, BMP, AVIF and PDF files into one local PDF.",
  "action": {
    "default_title": "Open PDF Combiner"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
